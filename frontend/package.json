    "@gravity-ui/table": "^1.13.0",
    "@gravity-ui/uikit": "^7.26.0",
    "@monaco-editor/react": "^4.7.0",
    "@tisoap/react-flow-smart-edge": "^4.0.1",
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.9.3",
    "atomic-router": "0.12.0",
    "atomic-router-react": "0.12.1",
    "bignumber.js": "9.1.2",
    "clsx": "2.1.0",
    "dagre": "^0.8.5",
    "effector": "23.4.4",
    "effector-react": "23.3.0",
    "elkjs": "^0.10.0",
    "final-form": "4.20.10",
    "history": "5.3.0",
    "lodash-es": "4.17.21",
    "moment": "2.30.1",
    "monaco-editor": "^0.54.0",
    "monaco-sql-languages": "^0.15.1",
    "monaco-yaml": "^5.2.3",
    "monaco-yql-languages": "^1.19.1",
    "nanoid": "5.0.9",
